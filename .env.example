# ——— Audio BM BiH — okruženje ———
# Kopirajte u .env i popunite stvarne vrijednosti.

# Tajni ključ Payload CMS-a (obavezno; generišite dug nasumičan niz)
PAYLOAD_SECRET=promijenite-me-dug-nasumican-niz

# Baza podataka:
#  - lokalni razvoj (SQLite): file:./audiobm.db
#  - produkcija (EU Postgres — Neon/Supabase EU): postgres://korisnik:lozinka@host:5432/audiobm
DATABASE_URL=file:./audiobm.db

# Javna adresa stranice (bez kose crte na kraju)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# E-pošta (SMTP — npr. Resend SMTP ili vlastiti server) [DNS_PLACEHOLDER: podesiti SPF/DKIM]
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Audio BM <info@audiobm.ba>"

# Cloudflare Turnstile (zaštita formi) — [PLACEHOLDER: kreirati na dash.cloudflare.com]
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Analitika (Plausible, EU) — [OWNER_CHOICE: Plausible ili GA4]
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
