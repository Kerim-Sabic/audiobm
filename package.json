{
  "name": "audiobm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Audio BM BiH — web stranica i CMS (slušni aparati i audiološke usluge)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:local": "pnpm clean:build-db && pnpm seed:local && cross-env PAYLOAD_SECRET=local-build-secret-change-me DATABASE_URL=file:./audiobm-build.db NEXT_PUBLIC_SERVER_URL=http://localhost:3000 next build",
    "clean:build-db": "node -e \"const fs=require('node:fs'); for (const file of ['audiobm-build.db','audiobm-build.db-shm','audiobm-build.db-wal']) fs.rmSync(file,{force:true})\"",
    "seed:local": "cross-env PAYLOAD_SECRET=local-build-secret-change-me DATABASE_URL=file:./audiobm-build.db NEXT_PUBLIC_SERVER_URL=http://localhost:3000 pnpm seed",
    "typecheck": "tsc --noEmit",
    "audit:prod": "pnpm audit --prod",
    "check": "pnpm typecheck",
    "seo:validate": "node scripts/seo-validate.mjs",
    "start": "next start",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "crawl": "node scripts/crawl.mjs",
    "brand": "node scripts/brand.mjs",
    "seed": "cross-env PAYLOAD_SEED=true payload run scripts/seed.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/db-sqlite": "3.85.1",
    "@payloadcms/email-nodemailer": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/storage-s3": "3.85.1",
    "@payloadcms/translations": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "@react-three/fiber": "^9.6.1",
    "graphql": "^16.11.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "payload": "3.85.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.34.5",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.184.1",
    "cross-env": "^7.0.3",
    "playwright": "1.57.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "3.4.11",
      "esbuild": "0.28.1",
      "nodemailer": "9.0.1",
      "postcss": "8.5.15",
      "undici": "7.28.0"
    },
    "onlyBuiltDependencies": [
      "@libsql/client",
      "@swc/core",
      "@tailwindcss/oxide",
      "esbuild",
      "libsql",
      "sharp",
      "unrs-resolver"
    ]
  }
}
